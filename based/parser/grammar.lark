start: definition* target+

definition: IDENTIFIER "(" param_list? ")" ":=" b_expr ";"

param_list: IDENTIFIER ("," IDENTIFIER)*

target: ">" b_expr ";" IDENTIFIER ";" TYPE

// Dangling-else problem solution -- "else" always binds with nearest "then"
?b_expr: matched
       | unmatched

?matched: "if" condition "then" matched "else" matched
        | expr

?unmatched: "if" condition "then" b_expr
          | "if" condition "then" matched "else" unmatched

condition: expr rel_op expr

!rel_op: "==" | "!=" | ">" | "<" | ">=" | "<="

?expr: term (("+" | "-") term)*
?term: power (("*" | "/") power)*
?power: atom ("^" power)?

?atom: NUMBER          -> number
     | IDENTIFIER      -> var
     | function_call
     | shorthand
     | "(" b_expr ")"

function_call: IDENTIFIER "(" arg_list? ")"
arg_list: expr ("," expr)*

!shorthand: ("sum" | "prod") "(" IDENTIFIER ";" expr ";" expr ";" expr ")"

TYPE: "double" | "float" | "int"
%import common.CNAME -> IDENTIFIER
%import common.NUMBER
%import common.WS
%ignore WS
