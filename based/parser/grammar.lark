start: definition* target+

definition: IDENTIFIER "(" param_list? ")" ":=" basic_expression ";"

param_list: IDENTIFIER ("," IDENTIFIER)*

target: ">" basic_expression ";" IDENTIFIER ";" TYPE ";"

?basic_expression: if_statement
                 | expr

if_statement: "if" condition "then" basic_expression (elif_block)* "else" basic_expression

elif_block: "elif" condition "then" basic_expression

?condition: log_or

?log_or: log_and ("or" log_and)*
?log_and: comparison ("and" comparison)*

?comparison: expr REL_OP expr
           | "(" condition ")"

?expr: term (("+" | "-") term)*
?term: power (("*" | "/") power)*
?power: atom ("^" power)?

?atom: NUMBER          -> number
     | IDENTIFIER      -> var
     | function_call
     | shorthand
     | "(" basic_expression ")"

function_call: IDENTIFIER "(" arg_list? ")"
arg_list: expr ("," expr)*

!shorthand: ("sum" | "prod") "(" IDENTIFIER ";" expr ";" expr ";" expr ")"

TYPE: "double" | "float" | "int"
REL_OP: "==" | "!=" | ">" | "<" | ">=" | "<="
%import common.CNAME -> IDENTIFIER
%import common.NUMBER
%import common.WS
%ignore WS
